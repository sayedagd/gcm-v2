    "@mantine/hooks": "^9.3.0",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.17.0",
    "browser-image-compression": "^2.0.2",
    "date-fns": "^4.4.0",
    "dayjs": "^1.11.21",
    "framer-motion": "^12.40.0",
    "html2canvas": "^1.4.1",
    "joi": "^18.2.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "next": "16.2.6",
