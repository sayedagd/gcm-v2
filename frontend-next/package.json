{
  "name": "frontend-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check:features": "node scripts/check-feature-structure.mjs",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "check:critical-deps": "node scripts/check-critical-deps.mjs",
    "lint": "npm run check:features && eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke:split": "node ../scripts/smoke/split-deployment-smoke.mjs",
    "parity:check": "node ../scripts/parity/parallel-parity-check.mjs",
    "ci:perf": "npm run build && npm run check:bundle-budget && npm run check:critical-deps"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
