# GCM Waste Backend Configuration Template
# [AR] قالب إعدادات الباك اند
# [EN] Backend configuration template

# --- Server Port ---
PORT=8080

# --- Database Connection (PostgreSQL) ---
# [AR] إعدادات قاعدة البيانات
# [EN] Database Settings

# POSTGRES_HOST
# Local development usually uses localhost.
# On Vercel, prefer DATABASE_URL and keep these values as fallback only.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123
POSTGRES_DB=gcm_waste

# --- Security ---
# [REQUIRED] Used for signing JWTs.
JWT_SECRET=your_secret_key_here
JWT_EXPIRES_IN=12h
AUTH_COOKIE_NAME=gcm_jwt
AUTH_CSRF_COOKIE_NAME=gcm_csrf
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:3000

# Endpoint-tier rate limiting overrides (optional)
RL_GLOBAL_MAX=1000
RL_AUTH_MAX=20
RL_PUBLIC_WRITE_MAX=40
RL_SSE_MAX=30
RL_AI_MAX=120
RL_ADMIN_MAX=30
METRIC_ALERT_ERROR_RATE_PERCENT_15M=5
METRIC_ALERT_AVG_LATENCY_MS_15M=1200
METRIC_ALERT_AUTH_FAILURES_15M=30
METRIC_ALERT_SSE_DISCONNECTS_15M=60
METRIC_ALERT_BACKUP_FAILURES_24H=1
CORS_ALLOW_VERCEL_PREVIEWS=false

# Request body limits (safer defaults; larger limits for upload-heavy endpoints)
BODY_LIMIT_DEFAULT_JSON=2mb
BODY_LIMIT_DEFAULT_URLENCODED=2mb
BODY_LIMIT_UPLOAD_JSON=25mb
BODY_LIMIT_UPLOAD_URLENCODED=10mb

# --- Direct URL (recommended on Vercel) ---
# Prefer sslmode=verify-full so pg/pg-connection-string keeps the same verification behavior in future major versions.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=verify-full

# --- Optional SMTP ---
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_USER=info@yourdomain.com
SMTP_PASS=your_password
SMTP_FROM="GCM ERP <info@yourdomain.com>"

# --- Optional Runtime Integrations ---
# AI integrations
# [REQUIRED for OCR] No fallback key exists in code.
GEMINI_API_KEY=
# [OPTIONAL] Used by shared AI assistant endpoints if enabled.
GROQ_API_KEY=
# [OPTIONAL] Used by carbon estimation proxy.
CLIMATIQ_API_KEY=

# WhatsApp web client is disabled by default in local/dev.
# Set to true only when you need WhatsApp notifications/QR flow.
ENABLE_WHATSAPP=false

# Boot-time schema sync is disabled by default in local/dev.
# Run /api/system/force-migrate or set this to true when you intentionally want startup migrations.
ENABLE_STARTUP_MIGRATIONS=false

# In-process cron is disabled by default. Prefer an external scheduler in production.
ENABLE_IN_PROCESS_CRON=false

# Runtime role controls whether background jobs are allowed in this process.
# api: request-serving runtime (default, stateless by design)
# worker: background execution runtime
PROCESS_ROLE=api

# Explicit override for local testing. Keep false in production API runtime.
ENABLE_IN_PROCESS_JOBS=false

# In module/serverless mode, keep startup jobs off unless explicitly needed.
ENABLE_SERVERLESS_STARTUP_JOBS=false

# Background job retry/backoff policy
OCR_WORKER_POLL_MS=3000
OCR_JOB_MAX_ATTEMPTS=5
OCR_JOB_BACKOFF_BASE_SECONDS=10

WHATSAPP_WORKER_POLL_MS=3000
WHATSAPP_JOB_MAX_ATTEMPTS=5
WHATSAPP_JOB_BACKOFF_BASE_SECONDS=10

# Realtime fanout broker (Phase 4)
EVENT_BUS_BROKER=local
EVENT_BUS_REDIS_CHANNEL=gcm:event-bus
REDIS_URL=
REDIS_ENABLED=false
RL_USE_REDIS_STORE=false
EVENT_BUS_REPLAY_LIMIT=200
EVENT_BUS_REPLAY_RETENTION_DAYS=7

# Metadata retention and archival policy knobs.
BACKUP_JOB_RUNS_RETENTION_DAYS=90
BACKUP_JOB_RUNS_ARCHIVE_DAYS=365
BACKUP_ARTIFACTS_RETENTION_DAYS=180
BACKUP_ARTIFACTS_ARCHIVE_DAYS=730

# Backup artifact object storage (required in production)
BACKUP_STORAGE_PROVIDER=local
S3_BACKUP_BUCKET=
S3_BACKUP_REGION=us-east-1
S3_BACKUP_ACCESS_KEY_ID=
S3_BACKUP_SECRET_ACCESS_KEY=
S3_BACKUP_ENDPOINT=
S3_BACKUP_FORCE_PATH_STYLE=false

# Legacy API deprecation controls.
LEGACY_API_SUNSET=2026-12-31
LEGACY_API_ENFORCE_AFTER_SUNSET=false
LEGACY_API_DEPRECATION_DOC_URL=https://github.com/sayedagd/gcm-v2/blob/main/backend/docs/api-v1-deprecation.md
SSE_MAX_CONNECTIONS_GLOBAL=1000
SSE_MAX_CONNECTIONS_PER_USER=3
SSE_MAX_CONNECTIONS_PER_COMPANY=100
SSE_MAX_CONNECTIONS_PER_SUPPLIER=100
SSE_MAX_CONNECTIONS_STAFF_POOL=200

# Fail-fast runtime config validation (recommended true outside tests).
ENABLE_RUNTIME_CONFIG_VALIDATION=true

# Managed database pooling
# DB_POOL_MODE: auto | pgbouncer | direct
# Production: keep DB_POOL_MODE as auto or pgbouncer and set DATABASE_POOL_URL.
# DB_POOL_MAX defaults by environment/role when omitted.
DB_POOL_MODE=auto
DATABASE_POOL_URL=
DB_POOL_MAX=50
DB_POOL_IDLE_MS=30000
DB_POOL_CONN_TIMEOUT_MS=10000
DB_MAX_CONNECTIONS=200
DB_RESERVED_CONNECTIONS=20
API_INSTANCE_COUNT=2
WORKER_INSTANCE_COUNT=2

# Optional one-time bootstrap admin creation. Leave empty unless you want startup/manual migrations to create an admin.
BOOTSTRAP_ADMIN_NAME=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_SYSTEM_PASSWORD=

# Path to Chrome/Chromium executable for Puppeteer (mainly server/Linux).
# Leave empty on Windows/local unless auto-detection fails.
CHROME_BIN=

# --- Local Startup Notes ---
# Validation notes:
# - JWT_SECRET must be present for protected routes to work.
# - GEMINI_API_KEY must be set for /api/ai/ocr/vision.
# - For production, prefer DATABASE_URL and do not rely on plaintext DB vars.
# - Keep AUTH_COOKIE_NAME and AUTH_CSRF_COOKIE_NAME aligned with frontend-next/.env.example.
# PORT is optional in local development.
# If PORT is not set and 8080 is busy, backend auto-retries on the next port.
# To force a fixed port, set PORT explicitly (for example PORT=8080).
