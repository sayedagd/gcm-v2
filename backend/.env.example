# GCM Waste Backend Configuration Template
# [AR] قالب إعدادات الباك اند
# [EN] Backend configuration template

# --- Server Port ---
PORT=8080

# --- Database Connection (PostgreSQL) ---
# [AR] إعدادات قاعدة البيانات
# [EN] Database Settings

# POSTGRES_HOST
# Local development usually uses localhost.
# On Vercel, prefer DATABASE_URL and keep these values as fallback only.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123
POSTGRES_DB=gcm_waste

# --- Security ---
JWT_SECRET=your_secret_key_here
CORS_ORIGIN=https://your-frontend-project.vercel.app
CORS_ALLOW_VERCEL_PREVIEWS=false

# --- Direct URL (recommended on Vercel) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Optional SMTP ---
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_USER=info@yourdomain.com
SMTP_PASS=your_password
SMTP_FROM="GCM ERP <info@yourdomain.com>"
