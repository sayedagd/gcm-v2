{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/[...path].js": {
      "includeFiles": "{src/**,database.js,fileService.js,validators/**,node_modules/**}"
    }
  },
  "rewrites": [
    { "source": "/api/v1/ping", "destination": "/api/ping" },
    { "source": "/api/v1/auth/login", "destination": "/api/login" },
    { "source": "/api/v1/auth/logout", "destination": "/api/login/signout" },
    { "source": "/api/v1/system/backup/status", "destination": "/api/backup-status" },
    { "source": "/api/v1/system/health/:path*", "destination": "/api/admin/health/:path*" },
    { "source": "/api/v1/system/metrics", "destination": "/api/admin/metrics" },
    { "source": "/api/v1/system/backup/:path*", "destination": "/api/opsbackup/:path*" },
    { "source": "/api/v1/system/settings/:path*", "destination": "/api/admin/settings/:path*" },
    { "source": "/api/v1/:path*", "destination": "/api/:path*" },
    { "source": "/auth/:path*", "destination": "/api/auth/:path*" },
    { "source": "/uploads/:path*", "destination": "/api/uploads/:path*" },
    { "source": "/system/:path*", "destination": "/api/system/:path*" }
  ]
}
