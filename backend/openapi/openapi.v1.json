{
  "openapi": "3.0.3",
  "info": {
    "title": "GCM Backend API",
    "version": "1.0.0",
    "description": "Versioned public API contract for GCM v2. All new clients should use /api/v1/* endpoints."
  },
  "servers": [
    {
      "url": "/",
      "description": "Same-origin backend"
    }
  ],
  "tags": [
    { "name": "Auth" },
    { "name": "Users" },
    { "name": "Companies" },
    { "name": "Projects" },
    { "name": "Trips" },
    { "name": "Services" },
    { "name": "Drivers" },
    { "name": "Vehicles" },
    { "name": "Suppliers" },
    { "name": "Facilities" },
    { "name": "Backup" },
    { "name": "Config" }
