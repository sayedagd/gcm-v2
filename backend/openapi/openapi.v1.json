  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "IdPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "ForbiddenError": {
        "description": "Forbidden",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "ValidationError": {
        "description": "Validation failed",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "description": "Authenticated user profile. Session token is issued via HttpOnly cookie, not response body.",
        "properties": {
          "user": { "$ref": "#/components/schemas/User" }
        },
        "additionalProperties": true
      },
      "SseTokenResponse": {
        "type": "object",
        "required": ["token", "expiresInSeconds"],
        "properties": {
          "token": { "type": "string" },
          "expiresInSeconds": { "type": "integer" }
        },
        "additionalProperties": true
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["status", "schemaVersion", "error", "code", "errorInfo"],
        "properties": {
          "status": { "type": "string", "example": "error" },
          "schemaVersion": { "type": "string", "example": "v1" },
          "errorInfo": {
            "type": "object",
            "properties": {
              "schemaVersion": { "type": "string", "example": "v1" },
              "code": { "type": "string" },
              "message": { "type": "string" },
              "errorEn": { "type": "string" },
              "errorAr": { "type": "string" },
              "traceId": { "type": "string" },
              "field": { "type": "string" },
              "details": { "type": "object", "additionalProperties": true }
            },
            "additionalProperties": true
          },
          "code": { "type": "string" },
          "error": { "type": "string", "description": "Legacy compatibility message" },
          "errorEn": { "type": "string" },
          "errorAr": { "type": "string" },
          "traceId": { "type": "string" },
          "field": { "type": "string" },
          "details": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      },
      "UpsertSuccess": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "success" },
          "id": { "type": "string" }
        },
        "additionalProperties": true
      },
      "DeleteSuccess": {
        "type": "object",
        "properties": {
          "status": { "type": "string" }
        },
        "additionalProperties": true
      },
