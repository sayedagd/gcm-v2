    "/api/v1/system/backup/status": {
      "get": {
        "tags": ["Backup"],
        "summary": "Get backup status",
        "parameters": [
          {
            "name": "job_id",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "Optional backup job id to inspect queued/running/completed job state"
          }
        ],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Backup status",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/BackupStatus" },
                    { "$ref": "#/components/schemas/BackupJobStatus" }
                  ]
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/ForbiddenError" }
        }
      }
    },
